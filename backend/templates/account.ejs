<!-- account.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title><%= title || 'Account Settings' %></title>
  
  <%- include('./partials/favicon') %>
  
  <!-- CSS Files -->
  <link rel="stylesheet" href="/static/css/litera-bootstrap.min.css">
  <link rel="stylesheet" href="/static/fontawesome/all.min.css">
  <link rel="stylesheet" href="/static/nav.css">
  <link rel="stylesheet" href="/static/flash.css">
  <link rel="stylesheet" href="/static/dist/bundle.css">
  
  <!-- Custom styles to match original application -->
  <link rel="stylesheet" href="/static/chat-custom.css">
  
  <!-- Account page specific styles -->
  <link rel="stylesheet" href="/static/css/account.css">

  <!-- Mobile navigation styles for CSP compliance -->
  <link rel="stylesheet" href="/static/css/navbar-mobile.css">
</head>
<body>
  <header>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
      <div class="container-fluid">
        <a class="navbar-brand" href="/sites">DevOpser Lite</a>

        <!-- hamburger toggler -->
        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarNav"
          aria-controls="navbarNav"
          aria-expanded="false"
          aria-label="Toggle navigation"
        >
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav me-auto">
            <li class="nav-item">
              <a class="nav-link" href="/sites">My Sites</a>
            </li>
          </ul>
          <ul class="navbar-nav">
            <% if (user && user.isAdmin) { %>
            <li class="nav-item">
              <a class="nav-link" href="/admin-panel">Admin</a>
            </li>
            <% } %>
            <li class="nav-item">
              <a class="nav-link active" href="/account">Account</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/auth/logout">Logout</a>
            </li>
          </ul>
        </div>
      </div>
    </nav>
  </header>
  

  <main class="container-fluid p-0">
    <!-- Flash Messages -->
    <% if (typeof message !== 'undefined' && message && message.length > 0) { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <%= message %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
    <% } %>
    <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
      <%= error %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
    <% } %>
    <div class="row app-container m-0">
      <div class="account-page-wrapper">
        <div class="account-page">
          <div class="account-container">
            <h2>Account Settings</h2>

            <!-- Account Information -->
            <div class="settings-section">
              <h3>Account Information</h3>
              <div class="account-info-grid">
                <div class="info-row">
                  <span class="info-label">Email:</span>
                  <span class="info-value"><%= user.email %></span>
                </div>
                <div class="info-row">
                  <span class="info-label">Name:</span>
                  <span class="info-value"><%= user.name || 'Not set' %></span>
                </div>
                <% if (user.googleId) { %>
                <div class="info-row">
                  <span class="info-label">Connected:</span>
                  <span class="info-value">
                    <span class="oauth-badge google">
                      <svg class="oauth-icon" width="16" height="16" viewBox="0 0 24 24">
                        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                        <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                      </svg>
                      Google
                    </span>
                  </span>
                </div>
                <% } %>
              </div>
            </div>

            <!-- Security Settings -->
            <div class="settings-section">
              <h3>Security</h3>

              <div class="account-info security-info">
                <div class="info-item">
                  <div class="info-label">Two-Factor Authentication</div>
                  <div class="info-value">
                    <span class="security-status"><%= user.mfaEnabled ? 'Enabled' : 'Not enabled' %></span>
                  </div>
                </div>
              </div>

              <div class="subscription-actions">
                <% if (!user.mfaEnabled) { %>
                  <a class="btn-manage btn-2fa" href="/auth/setup-authenticator">
                    Enable Two-Factor Authentication
                  </a>
                <% } else { %>
                  <form action="/auth/remove-authenticator" method="POST" class="d-inline" onsubmit="return confirm('Disable two-factor authentication?');">
                    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                    <button type="submit" class="btn-manage btn-2fa">Disable Two-Factor Authentication</button>
                  </form>
                <% } %>
              </div>

              <p class="security-description">
                Two-factor authentication adds an extra layer of security to your account by requiring a code from your phone in addition to your password.
              </p>
            </div>

            <!-- Subscription Information -->
            <div class="settings-section">
              <h3>Subscription Management</h3>
              <div class="subscription-info">
                <p>Subscription features coming soon!</p>
              </div>
            </div>

            <!-- AWS Account Information -->
            <div class="settings-section">
              <h3>Infrastructure</h3>
              <div class="account-info-grid">
                <div class="info-row">
                  <span class="info-label">AWS Account:</span>
                  <span class="info-value">
                    <% if (user.awsAccountId) { %>
                      <code><%= user.awsAccountId %></code>
                      <span class="aws-status <%= user.awsAccountStatus || 'pending' %>">
                        <%= user.awsAccountStatus || 'pending' %>
                      </span>
                    <% } else { %>
                      <span class="aws-status none">Not provisioned</span>
                    <% } %>
                  </span>
                </div>
                <% if (user.awsAccountCreatedAt) { %>
                <div class="info-row">
                  <span class="info-label">Created:</span>
                  <span class="info-value"><%= new Date(user.awsAccountCreatedAt).toLocaleDateString() %></span>
                </div>
                <% } %>
              </div>
            </div>

            <!-- Danger Zone -->
            <div class="danger-zone">
              <div class="danger-zone-header">
                <h3>Danger Zone</h3>
              </div>
              <div class="danger-zone-content">
                <div class="danger-item">
                  <div class="danger-item-info">
                    <h4>Delete Account</h4>
                    <p>Permanently delete your account and all associated data. This action cannot be undone.</p>
                    <ul>
                      <li>All your sites will be deactivated</li>
                      <li>Your AWS account and all deployed resources will be closed</li>
                      <li>All leads and analytics data will be deleted</li>
                      <li>Your account credentials will be removed</li>
                    </ul>
                  </div>
                  <button type="button" class="btn-danger-action" id="delete-account-btn">
                    Delete Account
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <!-- Delete Account Confirmation Modal -->
  <div class="modal-backdrop" id="delete-modal">
    <div class="delete-modal">
      <div class="delete-modal-header">
        <h3>Delete Your Account</h3>
      </div>
      <div class="delete-modal-body">
        <div class="warning-text">
          <strong>Warning:</strong> This action is permanent and cannot be undone. All your data, sites, and AWS resources will be permanently deleted.
        </div>
        <p>To confirm deletion, please type <strong>DELETE</strong> below:</p>
        <label for="confirm-delete">Confirmation</label>
        <input type="text" id="confirm-delete" placeholder="Type DELETE to confirm" autocomplete="off">
      </div>
      <div class="delete-modal-footer">
        <button type="button" class="btn-cancel" id="cancel-delete">Cancel</button>
        <form action="/account/delete" method="POST" id="delete-form">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
          <button type="submit" class="btn-delete-confirm" id="confirm-delete-btn" disabled>
            Delete My Account
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- JavaScript Files -->
  <script src="/static/js/bootstrap.bundle.min.js" defer></script>
  <script src="/static/flash.js" defer></script>
  <script src="/static/js/navbar-debug.js"></script>
  <script src="/static/js/mobile-nav.js" defer></script>
  <script src="/static/js/account.js" defer></script>
</body>
</html>
