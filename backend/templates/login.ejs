<% title = 'Login' %>
<link rel="stylesheet" href="/static/css/auth.css">
<%- include('./partials/favicon') %>

<div class="auth-form-container">
  <h2>Sign In</h2>

  <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
    <div class="flash error show">
      <%= error %>
    </div>
  <% } %>
  <% if (typeof message !== 'undefined' && message && message.length > 0) { %>
    <div class="flash info">
      <%= message %>
    </div>
  <% } %>

  <% if (typeof googleOAuthEnabled !== 'undefined' && googleOAuthEnabled) { %>
  <div class="social-auth">
    <a href="/auth/google" class="google-auth-button">
      <svg width="18" height="18" viewBox="0 0 24 24">
        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
        <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
      </svg>
      Continue with Google
    </a>
  </div>

  <div class="social-auth-divider">
    <span>or</span>
  </div>
  <% } %>

  <!-- Magic Link Authentication -->
  <div class="magic-link-auth">
    <div id="magic-link-email-step">
      <div class="form-group">
        <label for="magic-email">Email</label>
        <input type="email" id="magic-email" placeholder="Enter your email" required autofocus>
      </div>
      <button type="button" id="send-magic-code-btn" class="auth-button">
        Send Verification Code
      </button>
      <div id="magic-link-error" class="flash error"></div>
      <div id="magic-link-success" class="flash success"></div>
    </div>

    <div id="magic-link-code-step">
      <p class="code-instruction">Enter the 6-digit code sent to <strong id="magic-email-display"></strong></p>
      <p class="code-hint">Check your spam folder if you don't see it.</p>
      <div class="form-group">
        <input type="text" id="magic-code" class="magic-code-input" placeholder="000000" maxlength="6" pattern="[0-9]{6}" inputmode="numeric" required>
      </div>
      <button type="button" id="verify-magic-code-btn" class="auth-button">
        Verify Code
      </button>
      <div class="button-group">
        <button type="button" id="resend-code-btn" class="auth-button secondary">
          Resend Code
        </button>
        <button type="button" id="change-email-btn" class="auth-button secondary">
          Change Email
        </button>
      </div>
      <div id="magic-verify-error" class="flash error"></div>
      <div id="magic-verify-success" class="flash success"></div>
    </div>
  </div>
</div>

<script src="/static/js/auth.js"></script>
