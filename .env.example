# Database (PostgreSQL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=devdb
POSTGRES_USER=devuser
POSTGRES_PASSWORD=password

# Redis
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# LLM provider
# ---------------------------------------------------------------------------
# Which backend to use for the chat and website-agent models.
# Supported: bedrock (default), openai, anthropic
LLM_PROVIDER=bedrock

# --- bedrock (AWS) -------------
# Requires AWS credentials with bedrock:InvokeModel, bedrock:InvokeModelWithResponseStream,
# and Claude model access enabled in the Bedrock console.
REGION=us-east-1
# BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
#
# By default the backend uses the standard AWS credential chain (env vars,
# ~/.aws/credentials, EC2 instance role, ECS task role). Leave the line below
# COMMENTED OUT for a normal self-hosted setup — Bedrock calls will go
# directly to your own AWS account.
#
# Only set CUSTOMER_CROSS_ACCOUNT_ROLE_ARN if you're running in a platform
# account and need to AssumeRole into a different account (customer account,
# shared services account, sandbox account) to call Bedrock. This is the
# multi-tenant / managed-hosting pattern.
# CUSTOMER_CROSS_ACCOUNT_ROLE_ARN=arn:aws:iam::123456789012:role/YourBedrockRole

# --- openai --------------------
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=                  # override for Azure OpenAI / local vLLM / etc.

# --- anthropic (direct API) ----
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Shared generation settings (apply to all providers)
# MAX_TOKENS=4096
# TEMPERATURE=0.7

# ---------------------------------------------------------------------------
# Google OAuth (optional)
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Email (magic-link auth, password reset, MFA codes)
# ---------------------------------------------------------------------------
# Choose a transport. Default is AWS SES; flip to false for Gmail SMTP.
USE_SES=false

# --- Gmail SMTP (USE_SES=false) ------------
# Works with a Google account + app password (Google account > Security >
# 2-Step Verification > App passwords). You do NOT need AWS for this path.
#
# Leave MAIL_USERNAME and MAIL_PASSWORD blank to keep email disabled. Fill them
# in when you're ready — without a real value the email service is skipped
# (so magic-link login, password reset, and MFA codes won't send), but the
# app still boots cleanly. If you set placeholder values like "you@gmail.com"
# the SMTP client WILL try to authenticate against Gmail on startup and log
# an auth-failure stacktrace, so leave them blank until they're real.
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=

# --- AWS SES (USE_SES=true, default) -------
# SES_FROM_EMAIL=noreply@yourdomain.com
# The SES path uses the same AWS credentials as Bedrock. Verify the sender
# address in the SES console (or your whole domain) before sending.
